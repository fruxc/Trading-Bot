# Environment Configuration Template
# Copy this file to .env and fill in your values
# WARNING: NEVER commit .env to git!

# === LLM Integration ===
# Google Gemini API: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude (optional, for future integration)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# === Zerodha Broker Integration (LIVE TRADING) ===
# Get from: https://kite.zerodha.com/
ZERODHA_API_KEY=your-zerodha-api-key
ZERODHA_ACCESS_TOKEN=your-zerodha-access-token

# Paper Trading Mode (simulates trades without executing)
# Set to "true" to test without real money
USE_MOCK_BROKER=true

# === Risk Controls ===
# Options: CONSERVATIVE, MODERATE, AGGRESSIVE, PAPER_TRADING
RISK_PROFILE=CONSERVATIVE

# === Server Configuration ===
NODE_ENV=production
PORT=3000

# === Database Configuration ===
DB_PATH=./trades.db

# === Logging ===
LOG_LEVEL=info

# === Telegram Integration (Optional) ===
# For real Telegram notifications
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# === Backup Configuration ===
BACKUP_ENABLED=true
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# === Monitoring (Optional) ===
# Sentry for error tracking
SENTRY_DSN=

# === Market Data (Future) ===
# ALPHA_VANTAGE_API_KEY=for real market data
