# .gitignore - Trading Bot

# ========== CRITICAL: SECURITY & CREDENTIALS ==========
.env
.env.local
.env.*.local
.env.production.local
.env.test.local

# API Keys and Secrets (any file containing secrets)
secrets/
.secrets/
*.key
*.pem
*.p8
*.p12
.aws/
~/.aws/credentials

# ========== DEPENDENCIES ==========
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnp
.pnp.js

# ========== BUILD OUTPUT ==========
dist/
build/
out/
*.js
*.js.map
*.d.ts
*.d.ts.map
.tsbuildinfo

# ========== DATABASE & DATA ==========
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
trades.db
trading.db
*.sql
.sqlite3

# ========== LOGS ==========
logs/
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log
.pnpm-debug.log*

# ========== IDE & EDITOR ==========
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride
*.iml
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ========== OS FILES ==========
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ========== TESTING ==========
coverage/
.nyc_output/
.jest-cache/
.mocha-cache/
*.lcov
.coverage/

# ========== CACHE & TEMPORARY ==========
.turbo/
.next/
.nuxt/
.cache/
.parcel-cache/
.eslintcache
.node_repl_history
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ========== OPTIONAL NPM CACHE ==========
.npm
npm-shrinkwrap.json

# ========== PACKAGE MANAGER LOCK FILES ==========
!package-lock.json  # Uncomment if you want to track this
!yarn.lock           # Uncomment if you want to track this

# ========== RUNTIME & PROCESS FILES ==========
*.pid
*.seed
*.pid.lock
.nodemon.json
.prettierignore

# ========== VSCODE EXTENSIONS ==========
.vscode-test/
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json